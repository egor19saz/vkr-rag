# ======================================================================
# .env — скопируйте в .env и заполните свои значения
# НЕ коммитьте .env в git!
# ======================================================================

# GigaChat credentials (base64 от "ClientID:ClientSecret")
# Получить: https://developers.sber.ru/portal/products/gigachat
GIGACHAT_CREDENTIALS=ВАШ_BASE64_ТОКЕН_ЗДЕСЬ

# Тип аккаунта: GIGACHAT_API_PERS (личный) | GIGACHAT_API_CORP (корпоративный)
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель: GigaChat | GigaChat-Plus | GigaChat-Pro
GIGACHAT_MODEL=GigaChat

# URL GROBID (если запущен локально через Docker — оставьте как есть)
GROBID_URL=http://localhost:8070
